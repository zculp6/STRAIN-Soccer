filter(is_defending == TRUE) %>%
filter(in_attacking_third == TRUE) %>%
# For each frame, find the closest defender to the ball
group_by(Frame, time) %>%
arrange(distance_to_ball) %>%
slice(1) %>%
ungroup() %>%
arrange(time)
print(defensive_players)
# Calculate rate of change of distance (strain rate)
strain_data <- defensive_players %>%
arrange(time) %>%
mutate(
# Time difference between frames
time_diff = time - lag(time, default = first(time)),
# Distance change
distance_change = distance_to_ball - lag(distance_to_ball, default = first(distance_to_ball)),
# Rate of closure (negative = getting closer, positive = getting farther)
closure_rate = distance_change / time_diff,
# STRAIN calculation
strain_raw = - closure_rate / distance_to_ball,
# STRAIN score
STRAIN = pmax(0, strain_raw) # Ensure non-negative
) %>%
select(
Frame, time, Period,
possession_team,
possession_player,
attacking_direction,
in_attacking_third,
closest_defender = player,
defending_team = team,
Ball_x, Ball_y,
defender_x = x, defender_y = y,
distance_to_ball,
closure_rate,
STRAIN
)
return(strain_data)
}
# ============================================================================
# SOCCER STRAIN METRIC
# Measures defensive pressure on the ball in the attacking third
# ============================================================================
#' Calculate STRAIN metric for soccer
#'
#' STRAIN measures how quickly the closest defender is closing down the ball
#' in the opponent's defensive third (attacking third for the team in possession)
#'
#' Components:
#' 1. Distance to ball (closer = more pressure)
#' 2. Rate of distance change (closing speed)
#' 3. Only applied to closest defender
#' 4. Only calculated in attacking third
#'
#' @param player_data Data frame with columns: time, Frame, player, team, x, y
#' @param ball_data Data frame with columns: time, Frame, Ball_x, Ball_y
#' @param field_length Length of the field (default 105m for standard pitch)
#' @param field_width Width of the field (default 68m for standard pitch)
#' @param possession_threshold Distance threshold for possession (default 2m)
#' @return Data frame with STRAIN values per frame
calculate_soccer_strain <- function(player_data,
ball_data,
field_length = 105,
field_width = 68,
possession_threshold = 2)  {
# Join player and ball data
combined_data <- player_data %>%
inner_join(ball_data, by = c("time", "Frame")) %>%
# Calculate distance to ball for all players
mutate(
distance_to_ball = sqrt((x - Ball_x)^2 + (y - Ball_y)^2)
)
# Determine possession for each frame (closest player to ball)
possession_data <- combined_data %>%
group_by(Frame, time) %>%
arrange(distance_to_ball) %>%
slice(1) %>%
ungroup() %>%
select(Frame, time, Ball_x, Ball_y,
possession_team = team,
possession_player = player,
possession_distance = distance_to_ball)
# Add possession info back to all player data
combined_with_possession <- combined_data %>%
inner_join(possession_data, by = c("Frame", "time", "Ball_x", "Ball_y")) %>%
mutate(
# Determine if this player's team is attacking or defending
is_defending = (team != possession_team),
# Determine which third of the field based on attacking direction
# Attacking team attacks toward higher x values
attacking_direction = ifelse(possession_team == "Home", "right", "left"),
# Determine if ball is in attacking third (dangerous for defending team)
in_attacking_third = case_when(
attacking_direction == "right" ~ Ball_x >= 17.5,
attacking_direction == "left" ~ Ball_x <= -17.5,
TRUE ~ FALSE
)
)
# Filter for defending players in attacking third only
defensive_players <- combined_with_possession %>%
filter(is_defending == TRUE) %>%
filter(in_attacking_third == TRUE) %>%
# For each frame, find the closest defender to the ball
group_by(Frame, time) %>%
arrange(distance_to_ball) %>%
slice(1) %>%
ungroup() %>%
arrange(time)
print(defensive_players)
# Calculate rate of change of distance (strain rate)
strain_data <- defensive_players %>%
arrange(time) %>%
mutate(
# Time difference between frames
time_diff = time - lag(time, default = first(time)),
# Distance change
distance_change = distance_to_ball - lag(distance_to_ball, default = first(distance_to_ball)),
# Rate of closure (negative = getting closer, positive = getting farther)
closure_rate = distance_change / time_diff,
# STRAIN calculation
strain_raw = - closure_rate / distance_to_ball,
# STRAIN score
STRAIN = pmax(0, strain_raw) # Ensure non-negative
) %>%
select(
Frame, time, Period,
possession_team,
possession_player,
attacking_direction,
in_attacking_third,
closest_defender = player,
defending_team = team,
Ball_x, Ball_y,
defender_x = x, defender_y = y,
distance_to_ball,
closure_rate,
STRAIN
)
return(strain_data)
}
#' Aggregate STRAIN metrics over a time window
#'
#' @param strain_data Output from calculate_soccer_strain
#' @param window_seconds Time window for aggregation
#' @return Aggregated STRAIN metrics
aggregate_strain <- function(strain_data, window_seconds = 10) {
strain_data %>%
mutate(
time_window = floor(time / window_seconds) * window_seconds
) %>%
group_by(time_window, defending_team) %>%
summarise(
mean_STRAIN = mean(STRAIN, na.rm = TRUE),
max_STRAIN = max(STRAIN, na.rm = TRUE),
total_pressure_time = n(), # frames under pressure
mean_distance = mean(distance_to_ball, na.rm = TRUE),
mean_closure_rate = mean(closure_rate, na.rm = TRUE),
.groups = "drop"
)
}
#'
#' #' Identify high-pressure moments
#' #'
#' #' @param strain_data Output from calculate_soccer_strain
#' #' @param threshold STRAIN threshold for "high pressure"
#' #' @return Filtered data with only high-pressure moments
#' identify_pressure_moments <- function(strain_data, threshold = 50) {
#'   strain_data %>%
#'     filter(STRAIN >= threshold) %>%
#'     arrange(desc(STRAIN))
#' }
#'
#' #' Analyze possession transitions
#' #'
#' #' @param strain_data Output from calculate_soccer_strain
#' #' @return Data frame with possession change events
