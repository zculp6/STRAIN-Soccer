#' }
#'
#' #' Get STRAIN context around possession changes
#' #'
#' #' @param strain_data Output from calculate_soccer_strain
#' #' @param transition_data Output from analyze_possession_transitions
#' #' @param window_seconds Time window before/after transition
#' #' @return Aggregated STRAIN around transitions
#' strain_around_transitions <- function(strain_data, transition_data, window_seconds = 5) {
#'
#'   results <- list()
#'
#'   for(i in 1:nrow(transition_data)) {
#'     trans_time <- transition_data$time[i]
#'
#'     window_data <- strain_data %>%
#'       filter(time >= trans_time - window_seconds,
#'              time <= trans_time + window_seconds) %>%
#'       mutate(
#'         transition_id = i,
#'         time_from_transition = time - trans_time,
#'         transition_type = paste(transition_data$from_team[i], "to",
#'                                transition_data$to_team[i])
#'       )
#'
#'     results[[i]] <- window_data
#'   }
#'
#'   bind_rows(results)
#' }
# Example: Home team attacking to the right
strain_results <- calculate_soccer_strain(
player_data = all_players,
ball_data = ball_data,
field_length = 105,
field_width = 68
)
# Summary by possession team
print("\nSummary by Possession Team:")
strain_results %>%
group_by(possession_team) %>%
summarise(
frames_under_pressure = n(),
mean_STRAIN = mean(STRAIN, na.rm = TRUE),
