calculate_soccer_strain <- function(player_data,
ball_data,
possession_threshold = 1)  {  # Distance threshold for possession change
# Join player and ball data
combined_data <- player_data %>%
inner_join(ball_data, by = c("time", "Frame")) %>%
# Calculate distance to ball for all players
mutate(
distance_to_ball = sqrt((x - Ball_x)^2 + (y - Ball_y)^2)
)
# Determine initial possession and track changes frame by frame
possession_data <- combined_data %>%
group_by(Frame, time) %>%
arrange(distance_to_ball) %>%
slice(1) %>%  # Get closest player per frame
ungroup() %>%
arrange(Frame) %>%
mutate(
# Initialize possession variables
possession_team = team,
possession_player = player,
possession_distance = distance_to_ball
)
# Apply sticky possession logic
for (i in 2:nrow(possession_data)) {
current_team <- possession_data$team[i]
current_distance <- possession_data$distance_to_ball[i]
previous_team <- possession_data$possession_team[i-1]
# Only change possession if:
# 1. New team is different from current possession team, AND
# 2. New team's closest player is within threshold distance
if (current_team != previous_team && current_distance <= possession_threshold) {
# Change possession
possession_data$possession_team[i] <- current_team
possession_data$possession_player[i] <- possession_data$player[i]
} else {
# Keep previous possession
possession_data$possession_team[i] <- previous_team
possession_data$possession_player[i] <- possession_data$possession_player[i-1]
}
possession_data$possession_distance[i] <- current_distance
}
# Select final possession info
possession_final <- possession_data %>%
select(Frame, time, Ball_x, Ball_y,
possession_team,
possession_player,
possession_distance)
# Add possession info back to all player data
combined_with_possession <- combined_data %>%
inner_join(possession_final, by = c("Frame", "time", "Ball_x", "Ball_y")) %>%
mutate(
# Determine if this player's team is attacking or defending
is_defending = (team != possession_team),
# Determine which third of the field based on attacking direction
# Attacking team attacks toward higher x values
attacking_direction = ifelse(possession_team == "Home", "right", "left"),
# Determine if ball is in attacking third (dangerous for defending team)
in_attacking_third = case_when(
attacking_direction == "right" ~ Ball_x >= 17.5,
attacking_direction == "left" ~ Ball_x <= -17.5,
TRUE ~ FALSE
)
)
# Filter for defending players in attacking third only
defensive_players <- combined_with_possession %>%
filter(is_defending == TRUE) %>%
filter(in_attacking_third == TRUE) %>%
# For each frame, find the closest defender to the ball
group_by(Frame, time) %>%
arrange(distance_to_ball) %>%
slice(1) %>%
ungroup() %>%
arrange(time)
# Calculate rate of change of distance (strain rate)
strain_data <- defensive_players %>%
arrange(time) %>%
mutate(
# Time difference between frames
time_diff = time - lag(time),
# Distance change
distance_change = distance_to_ball - lag(distance_to_ball),
# Rate of closure (negative = getting closer, positive = getting farther)
closure_rate = if_else(!is.na(time_diff) & time_diff > 0,
distance_change / time_diff,
NA_real_),
# STRAIN calculation with safeguards
# Add minimum distance to prevent division by zero
distance_safe = pmax(distance_to_ball, 0.5),
strain_raw = if_else(!is.na(closure_rate),
-closure_rate / distance_safe,
NA_real_),
# STRAIN score (non-negative)
STRAIN = pmax(0, strain_raw, na.rm = TRUE)
) %>%
select(
Frame, time, Period,
possession_team,
possession_player,
attacking_direction,
in_attacking_third,
closest_defender = player,
defending_team = team,
Ball_x, Ball_y,
defender_x = x, defender_y = y,
distance_to_ball,
closure_rate,
STRAIN
)
return(strain_data)
}
# Example: Home team attacking to the right
strain_results <- calculate_soccer_strain(
player_data = all_players,
ball_data = ball_data,
field_length = 105,
field_width = 68
)
# Example: Home team attacking to the right
strain_results <- calculate_soccer_strain(
player_data = all_players,
ball_data = ball_data
)
calculate_soccer_strain <- function(player_data,
ball_data,
possession_threshold = 1)  {
# Join player and ball data
combined_data <- player_data %>%
inner_join(ball_data, by = c("time", "Frame")) %>%
# Calculate distance to ball for all players
mutate(
distance_to_ball = sqrt((x - Ball_x)^2 + (y - Ball_y)^2)
)
# Determine initial possession and track changes frame by frame
possession_data <- combined_data %>%
group_by(Frame, time) %>%
arrange(distance_to_ball) %>%
slice(1) %>%  # Get closest player per frame
ungroup() %>%
arrange(Frame) %>%
mutate(
# Initialize possession variables
possession_team = team,
possession_player = player,
possession_distance = distance_to_ball
)
# Apply sticky possession logic
for (i in 2:nrow(possession_data)) {
current_team <- possession_data$team[i]
current_distance <- possession_data$distance_to_ball[i]
previous_team <- possession_data$possession_team[i-1]
# Check for NA values before comparison
if (!is.na(current_team) && !is.na(previous_team) &&
!is.na(current_distance) && !is.na(possession_threshold)) {
# Only change possession if:
# 1. New team is different from current possession team, AND
# 2. New team's closest player is within threshold distance
if (current_team != previous_team && current_distance <= possession_threshold) {
# Change possession
possession_data$possession_team[i] <- current_team
possession_data$possession_player[i] <- possession_data$player[i]
} else {
# Keep previous possession
possession_data$possession_team[i] <- previous_team
possession_data$possession_player[i] <- possession_data$possession_player[i-1]
}
} else {
# If NA values present, keep previous possession
possession_data$possession_team[i] <- previous_team
possession_data$possession_player[i] <- possession_data$possession_player[i-1]
}
possession_data$possession_distance[i] <- current_distance
}
# Select final possession info
possession_final <- possession_data %>%
select(Frame, time, Ball_x, Ball_y,
possession_team,
possession_player,
possession_distance)
# Add possession info back to all player data
combined_with_possession <- combined_data %>%
inner_join(possession_final, by = c("Frame", "time", "Ball_x", "Ball_y")) %>%
mutate(
# Determine if this player's team is attacking or defending
is_defending = (team != possession_team),
# Determine which third of the field based on attacking direction
attacking_direction = ifelse(possession_team == "Home", "right", "left"),
# Determine if ball is in attacking third (dangerous for defending team)
in_attacking_third = case_when(
attacking_direction == "right" ~ Ball_x >= 17.5,
attacking_direction == "left" ~ Ball_x <= -17.5,
TRUE ~ FALSE
)
)
# Filter for defending players in attacking third only
defensive_players <- combined_with_possession %>%
filter(is_defending == TRUE, in_attacking_third == TRUE) %>%
# For each frame, find the closest defender to the ball
group_by(Frame, time) %>%
arrange(distance_to_ball) %>%
slice(1) %>%
ungroup() %>%
arrange(time)
# Calculate rate of change of distance (strain rate)
strain_data <- defensive_players %>%
arrange(time) %>%
mutate(
# Time difference between frames
time_diff = time - lag(time),
# Distance change
distance_change = distance_to_ball - lag(distance_to_ball),
# Rate of closure (negative = getting closer, positive = getting farther)
closure_rate = if_else(!is.na(time_diff) & time_diff > 0,
distance_change / time_diff,
NA_real_),
# STRAIN calculation with safeguards
distance_safe = pmax(distance_to_ball, 0.5),
strain_raw = if_else(!is.na(closure_rate),
-closure_rate / distance_safe,
NA_real_),
# STRAIN score (non-negative, cap at reasonable max)
STRAIN = pmin(pmax(0, strain_raw, na.rm = TRUE), 10)
) %>%
select(
Frame, time, Period,
possession_team,
possession_player,
attacking_direction,
in_attacking_third,
closest_defender = player,
defending_team = team,
Ball_x, Ball_y,
defender_x = x, defender_y = y,
distance_to_ball,
closure_rate,
STRAIN
)
return(strain_data)
}
